{
  "name": "ai-team-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "type-check": "tsc --noEmit",
    "docs:api": "typedoc",
    "docs:api:watch": "typedoc --watch",
    "docs:storybook": "storybook build -o docs/storybook",
    "docs:clean": "rm -rf docs/api docs/storybook",
    "docs:build": "npm run docs:api && npm run docs:storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "vitest": {
    "environment": "jsdom"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.42.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/react-window": "^1.8.8",
    "better-sqlite3": "^12.6.2",
    "jspdf": "^4.2.0",
    "next": "^16.1.6",
    "next-swagger-doc": "^0.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-ui-react": "^5.32.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@storybook/addon-a11y": "^10.2.15",
    "@storybook/addon-docs": "^10.2.15",
    "@storybook/addon-onboarding": "^10.2.15",
    "@storybook/nextjs": "^10.2.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-storybook": "^10.2.15",
    "jsdom": "^28.1.0",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.4.33",
    "prettier": "^3.8.1",
    "storybook": "^10.2.15",
    "tailwindcss": "^3.4.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
