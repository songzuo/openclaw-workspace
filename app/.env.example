# GitHub API 配置

# GitHub 仓库信息 (替换为你的实际仓库)
NEXT_PUBLIC_GITHUB_OWNER=songzhuo
NEXT_PUBLIC_GITHUB_REPO=openclaw-workspace

# GitHub Personal Access Token (可选，但推荐用于更高的 API 限制)
# 创建方式：https://github.com/settings/tokens
# 需要的权限：repo, read:user
NEXT_PUBLIC_GITHUB_TOKEN=

# 刷新间隔 (毫秒)
NEXT_PUBLIC_REFRESH_INTERVAL=30000

# Sentry 错误监控配置

# Sentry DSN (Data Source Name)
# 获取方式：https://sentry.io/settings/projects/
# 示例：https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry 环境设置 (可选)
# 默认：development, production, test
NODE_ENV=development

# Sentry Release 版本 (可选)
# 默认：1.0.0 或从 package.json 读取
NEXT_PUBLIC_APP_VERSION=1.0.0
SENTRY_RELEASE=

# Sentry 启用开关 (可选)
# 设置为 true 以在开发环境启用 Sentry
# 默认：仅在 production 启用
SENTRY_ENABLED=false

# 性能监控采样率 (可选，0.0-1.0)
# 1.0 = 100% 采样，0.1 = 10% 采样
# 默认：1.0
SENTRY_TRACES_SAMPLE_RATE=1.0

# Sentry 环境标识 (可选)
# 默认：NODE_ENV 值
SENTRY_ENVIRONMENT=development

# ============================
# JWT 认证配置
# ============================

# JWT 密钥 (生产环境必需)
# 用于签名和验证 JWT 令牌的安全密钥
# 生成方式：openssl rand -base64 32
# 注意：至少 32 字符，生产环境必须设置
JWT_SECRET=

# JWT 过期时间 (可选)
# 默认：7d (7天)
# 格式：Xs (秒), Xm (分), Xh (小时), Xd (天)
JWT_EXPIRES_IN=7d

# JWT 发行者 (可选)
# 默认：ai-team-dashboard
JWT_ISSUER=ai-team-dashboard

# JWT 受众 (可选)
# 默认：ai-team-dashboard-users
JWT_AUDIENCE=ai-team-dashboard-users

# ============================
# 管理员配置
# ============================

# 管理员密码 (生产环境必需)
# 用于管理员登录的密码
# 注意：应使用强密码，不要使用默认密码
ADMIN_PASSWORD=

# ============================
# 数据库配置 (可选)
# ============================

# 数据库文件路径 (可选)
# 默认：./data/database.sqlite
DATABASE_PATH=

# ============================
# GitHub API 配置
# ============================

# GitHub 仓库信息 (替换为你的实际仓库)
NEXT_PUBLIC_GITHUB_OWNER=songzhuo
NEXT_PUBLIC_GITHUB_REPO=openclaw-workspace

# GitHub Personal Access Token (可选，但推荐用于更高的 API 限制)
# 创建方式：https://github.com/settings/tokens
# 需要的权限：repo, read:user
NEXT_PUBLIC_GITHUB_TOKEN=

# 刷新间隔 (毫秒)
NEXT_PUBLIC_REFRESH_INTERVAL=30000

# ============================
# Sentry 错误监控配置
# ============================

# Sentry DSN (Data Source Name)
# 获取方式：https://sentry.io/settings/projects/
# 示例：https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry 环境设置 (可选)
# 默认：development, production, test
NODE_ENV=development

# Sentry Release 版本 (可选)
# 默认：1.0.0 或从 package.json 读取
NEXT_PUBLIC_APP_VERSION=1.0.0
SENTRY_RELEASE=

# Sentry 启用开关 (可选)
# 设置为 true 以在开发环境启用 Sentry
# 默认：仅在 production 启用
SENTRY_ENABLED=false

# 性能监控采样率 (可选，0.0-1.0)
# 1.0 = 100% 采样，0.1 = 10% 采样
# 默认：1.0
SENTRY_TRACES_SAMPLE_RATE=1.0
